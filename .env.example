# Copy to .env and fill in real values. .env is gitignored;
# .env.example is tracked as the template.
#
# Load into your shell before running tests or examples:
#     set -a; source .env; set +a
#
# After that, go test / go run inherit these vars automatically.

# Required for the anthropic integration test and examples/basic.
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# Future passes will use these. Leave blank for now.
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
